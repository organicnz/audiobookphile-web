# Audiobookshelf Client Environment Variables

# --- Supabase Configuration ---
# Your Supabase Project URL (e.g., https://xyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase Project Anonymous Key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your Supabase Service Role Key (server-side only — never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# --- Production Deployment ---
# The public URL of your application (required for OAuth redirects)
NEXT_PUBLIC_SITE_URL=https://audiobookshelf.foodshare.club

# --- Audiobookshelf Backend Connection ---
# The hostname and port of your production Audiobookshelf server
HOST=localhost
PORT=3333
