# Audiobookphile Environment Variables
# Copy this file to .env.local for local development.
#
# Vercel environment legend used in comments below:
#   [Prod]    — Vercel Production environment
#   [Preview] — Vercel Preview deployments (PR branches)
#   [Dev]     — Vercel Development environment / local .env.local

# =============================================================================
# BUILD-TIME VARIABLES (NEXT_PUBLIC_*)
# These are inlined into the browser bundle at build time.
# They MUST be set in every Vercel environment that triggers a build.
# =============================================================================

# --- Supabase Client ---

# [Prod / Preview / Dev — REQUIRED]
# Your Supabase Project URL (e.g., https://xyz.supabase.co).
# Also used in next.config.ts to build the /api/* rewrite destination.
# Missing: all Supabase client calls fail; /api/* rewrites resolve to
# "undefined/functions/v1/api/*", breaking every API route.
NEXT_PUBLIC_SUPABASE_URL=

# [Prod / Preview / Dev — REQUIRED]
# Your Supabase Project Anonymous (public) key — safe to expose to the browser.
# Missing: Supabase client cannot initialise; auth and database queries fail.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Site URL ---

# [Prod / Preview / Dev — REQUIRED]
# The canonical public URL of this deployment (no trailing slash).
# Used for OAuth redirect URLs and email confirmation links.
# Missing: auth callbacks and email links redirect to the wrong origin,
# breaking sign-in / sign-up flows. Falls back to NEXT_PUBLIC_VERCEL_URL /
# VERCEL_URL when absent, which may produce mismatched redirect URLs.
# Set per-environment in Vercel (e.g., https://audiobookphile.com for Prod,
# the branch preview URL for Preview, http://localhost:3000 for Dev).
NEXT_PUBLIC_SITE_URL=https://audiobookphile-web.vercel.app

# --- Analytics (PostHog) ---

# [Prod — REQUIRED; Preview / Dev — optional]
# Your PostHog project API key (format: phc_...).
# Missing: PostHog initialises with the placeholder value "phc_placeholder"
# so the app does not crash, but no real analytics events are captured.
NEXT_PUBLIC_POSTHOG_KEY=

# [Prod — REQUIRED if NEXT_PUBLIC_POSTHOG_KEY is set; Preview / Dev — optional]
# PostHog ingestion host. Defaults to https://us.i.posthog.com when absent.
# Change if you use a custom PostHog domain or the EU cloud region.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# SERVER-SIDE VARIABLES
# Never prefix these with NEXT_PUBLIC_. They are only available in
# Next.js API routes, Server Actions, and server components.
# =============================================================================

# --- Supabase Service Role ---

# [Prod / Preview — REQUIRED; Dev — REQUIRED for admin operations]
# Canonical name expected by src/lib/supabase/service-role.ts.
# The codebase falls back to SUPABASE_SERVICE_KEY when this is absent
# (i.e. process.env.SUPABASE_SERVICE_ROLE_KEY ?? process.env.SUPABASE_SERVICE_KEY),
# so either name is accepted during a rename transition. Prefer this canonical
# name for all new configurations to avoid relying on the fallback.
# Missing (both names absent): createServiceRoleClient() throws
# "Missing environment variable: SUPABASE_SERVICE_ROLE_KEY" and all
# server-side admin operations fail with a 500 error.
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SERVICE_KEY=   ← accepted alias / legacy fallback; use SUPABASE_SERVICE_ROLE_KEY instead

# =============================================================================
# STORAGE — BACKBLAZE B2 / S3-COMPATIBLE (OPTIONAL)
# All five variables below are optional as a group. When any of them is
# absent the storage sync code automatically falls back to Supabase storage
# without crashing (graceful degradation via optional chaining in
# storageSync.ts). Set them only in environments where B2 sync is intended.
# =============================================================================

# [Prod / Preview / Dev — optional; omit to use Supabase storage instead]
# S3-compatible endpoint for your B2 bucket
# (e.g., https://s3.us-west-004.backblazeb2.com).
B2_ENDPOINT=

# [Prod / Preview / Dev — optional]
# Name of the B2 bucket that holds your audiobook files.
B2_BUCKET_NAME=

# [Prod / Preview / Dev — optional]
# B2 key ID (analogous to AWS_ACCESS_KEY_ID).
B2_KEY_ID=

# [Prod / Preview / Dev — optional]
# B2 application key (analogous to AWS_SECRET_ACCESS_KEY).
B2_APP_KEY=

# [Prod / Preview / Dev — optional]
# B2 region string used to construct the S3-compatible endpoint.
B2_REGION=us-west-004

# =============================================================================
# ADVANCED CONFIGURATION (OPTIONAL)
# Uncomment and adjust if you need non-default token expiry values.
# =============================================================================

# REFRESH_TOKEN_EXPIRY=604800
# ACCESS_TOKEN_EXPIRY=43200
# NEXT_PUBLIC_API_URL=
