# Audiobookphile Environment Variables

# --- Supabase Configuration ---
# Your Supabase Project URL (e.g., https://xyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase Project Anonymous Key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your Supabase Service Role Key (server-side only — never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# --- Production Deployment ---
# The public URL of your application (required for OAuth and email redirect links)
# Use your Vercel deployment URL or custom domain once DNS is resolved
NEXT_PUBLIC_SITE_URL=https://audiobookphile-web.vercel.app

# --- Storage (Backblaze B2 / S3 Compatible) ---
# Used for syncing audiobooks from S3-compatible storage if you bypass Supabase storage
B2_ENDPOINT=
B2_BUCKET_NAME=
B2_REGION=us-west-004
B2_KEY_ID=
B2_APP_KEY=

# --- Advanced Configuration (Optional) ---
# REFRESH_TOKEN_EXPIRY=604800
# ACCESS_TOKEN_EXPIRY=43200
# NEXT_PUBLIC_API_URL=
