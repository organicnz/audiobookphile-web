{
  "name": "audiobookphile-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "next dev",
    "build": "rm -rf .next && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "types:sync": "cd ../audiobookphile-backend && supabase gen types typescript --linked > ../audiobookphile-web/src/types/supabase.ts",
    "cy:open": "cypress open",
    "cy:comp": "cypress open --component --browser chrome",
    "test": "cypress run --component --browser chrome",
    "test:spec": "cypress run --component --browser chrome --spec",
    "cy:e2e": "cypress open --e2e --browser chrome",
    "test:e2e": "cypress run --e2e --browser chrome",
    "cy:brave": "cypress open --component --browser \"C:\\Program Files\\BraveSoftware\\Brave-Browser\\Application\\brave.exe:chrome\"",
    "test:brave": "cypress run --component --browser \"C:\\Program Files\\BraveSoftware\\Brave-Browser\\Application\\brave.exe:chrome\"",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "sync:ios": "bun run scripts/generate-swift-models.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@floating-ui/react-dom": "^2.1.6",
    "@formkit/drag-and-drop": "^0.5.3",
    "@sentry/nextjs": "^10.58.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@vercel/analytics": "^2.0.1",
    "backblaze-b2": "^1.7.1",
    "clsx": "^2.1.1",
    "cronstrue": "^3.3.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.6.15",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "next-intl": "^4.11.0",
    "posthog-js": "^1.386.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-transition-group": "^4.4.5",
    "slate": "^0.118.1",
    "slate-history": "^0.113.1",
    "slate-react": "^0.117.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tus-js-client": "^4.3.1",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "cypress": "^15.6.0",
    "cypress-plugin-tab": "^1.0.5",
    "cypress-real-events": "^1.15.0",
    "eslint": "^9.36.0",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier-plugin-sort-json": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "size-limit": "^12.1.0",
    "supabase": "^2.98.2",
    "tailwindcss": "^4",
    "ts-morph": "^28.0.0",
    "typescript": "^5"
  },
  "devEngines": {
    "runtime": {
      "name": "bun",
      "onFail": "error"
    },
    "packageManager": {
      "name": "bun",
      "version": "1.3.9",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=22.15.0",
    "bun": ">=1.3.9"
  },
  "size-limit": [
    {
      "path": ".next/static/chunks/**/*.js",
      "limit": "500 kB"
    }
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
